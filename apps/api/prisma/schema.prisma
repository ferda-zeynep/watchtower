datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Event {
  id         String   @id @default(uuid())
  projectKey String
  type       String
  message    String
  stack      String?
  url        String?
  userAgent  String?
  timestamp  DateTime @default(now())
}